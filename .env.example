# AI新聞 - 環境変数テンプレート
# このファイルを .env にコピーしてローカル開発時に使用
# 本番は GitHub Secrets に登録する（このファイルは .gitignore に追加すること）

# ─── 必須 ───────────────────────────────────────
# Google AI Studio から取得
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Notion Integration Token
# https://www.notion.so/my-integrations で「AI新聞Bot」を作成
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxx

# Notion の記事データベース ID
# DB の URL: https://notion.so/xxxx?v=yyyy → xxxx の部分
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Discord Webhook URL
# サーバー設定 → 連携サービス → ウェブフック → 新しいウェブフック
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/xxxx

# ─── 任意（高レートリミット解除）────────────────
# Jina AI の API Key（なくても動く。あると高速・安定）
# https://jina.ai/
JINA_API_KEY=jina_xxxxxxxxxxxxxxxxxxxx
